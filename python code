    def toggleAllRecordings(self):
        self.all_recording = not self.all_recording
        for i, name in enumerate(self.sensor_names):
            self.recording_state[name] = self.all_recording
            if self.all_recording:
                self.start_buttons[i].setEnabled(False)
                self.stop_buttons[i].setEnabled(True)
            else:
                self.start_buttons[i].setEnabled(True)
                self.stop_buttons[i].setEnabled(False)
        if self.all_recording:
            self.all_recordings_button.setText("Stop All Recordings")
        else:
            self.all_recordings_button.setText("Start All Recordings")

    def resetData(self):
        """Reset recorded data and clear plots."""
        self.data_record = {name: [] for name in self.sensor_names}
        for name, line in self.temp_lines.items():
            line.set_data([], [])
        for name, line in self.hum_lines.items():
            line.set_data([], [])
        self.temp_canvas.draw()
        self.hum_canvas.draw()

    def startRecording(self, idx):
        sensor_name = self.sensor_names[idx]
        self.recording_state[sensor_name] = True
        self.start_buttons[idx].setEnabled(False)
        self.stop_buttons[idx].setEnabled(True)

    def stopRecording(self, idx):
        sensor_name = self.sensor_names[idx]
        self.recording_state[sensor_name] = False
        self.start_buttons[idx].setEnabled(True)
        self.stop_buttons[idx].setEnabled(False)

    def updateData(self):
        """Update sensor displays, flags, counts, and plots using the latest recorded data."""
        # Update sensor displays and extra info.
        for i, name in enumerate(self.sensor_names):
            if self.data_record[name]:
                latest_value = self.data_record[name][-1][1]
                if self.sensor_types[i] == "temperature":
                    self.sensor_value_buttons[i].setText(f"{latest_value:.1f} C")
                elif self.sensor_types[i] == "humidity":
                    self.sensor_value_buttons[i].setText(f"{latest_value:.1f} %")
                elif self.sensor_types[i] == "co2":
                    self.sensor_value_buttons[i].setText(f"{latest_value:.0f} ppm")
                                                         
                
                
            # Update recording count label.
            self.recording_count_labels[i].setText(str(len(self.data_record[name])))
            
            # Update flag indicator: green if data received within last 10 se
            if self.data_record[name]:
                last_time = datetime.fromisoformat(self.data_record[name][-1][0])
                if (datetime.now() - last_time).total_seconds() < 10:
                    self.flag_labels[i].setStyleSheet("color: green; font-size: 16px;")
                else:
                    self.flag_labels[i].setStyleSheet("color: red; font-size: 16px;")
            else:
                self.flag_labels[i].setStyleSheet("color: red; font-size: 16px;")

        # Update temperature plot (for indices 0,1,2,3,4,6)
        temp_times_all = []
        for i in [0, 2, 4]:
            name = self.sensor_names[i]
            data = self.data_record[name]
            if self.display_checkboxes[i].isChecked() and data:
                times = [datetime.fromisoformat(entry[0]) for entry in data]
                values = [entry[1] for entry in data]
                self.temp_lines[name].set_data(times, values)
                temp_times_all.extend(times)
            else:
                self.temp_lines[name].set_data([], [])
        if temp_times_all:
            self.ax_temp.set_xlim(min(temp_times_all), max(temp_times_all))
        self.ax_temp.relim()
        self.ax_temp.autoscale_view(scalex=False, scaley=True)
        self.temp_canvas.draw()

        # Update humidity plot (for indices 5,7)
        hum_times_all = []
        for i in [1, 5]:
            name = self.sensor_names[i]
            data = self.data_record[name]
            if self.display_checkboxes[i].isChecked() and data:
                times = [datetime.fromisoformat(entry[0]) for entry in data]
                values = [entry[1] for entry in data]
                self.hum_lines[name].set_data(times, values)
                hum_times_all.extend(times)
            else:
                self.hum_lines[name].set_data([], [])
        if hum_times_all:
            self.ax_hum.set_xlim(min(hum_times_all), max(hum_times_all))
        self.ax_hum.relim()
        self.ax_hum.autoscale_view(scalex=False, scaley=True)
        self.hum_canvas.draw()

        # Update any open sensor-specific plot windows.
        for window in self.sensor_windows.values():
            window.updatePlot()
            
        # Update CO2 plot
        co2_times_all = []
        name = "SCD4X CO2"
        data = self.data_record[name]   

        if data:
            times = [datetime.fromisoformat(entry[0]) for entry in data]
            values = [entry[1] for entry in data]
            self.co2_lines[name].set_data(times, values)
            co2_times_all.extend(times)
        else:
            self.co2_lines[name].set_data([], [])

        if co2_times_all:
            self.ax_co2.set_xlim(min(co2_times_all), max(co2_times_all))

        self.ax_co2.relim()
        self.ax_co2.autoscale_view(scalex=False, scaley=True)
        self.co2_canvas.draw()



    def onSerialData(self, sensor_data):
          # Arduino actual format: [MCP9808_TEMP, SHT45_TEMP, SHT45_HUMIDITY, SCD4X_CO2, SCD4X_TEMP, SCD4X_HUMIDITY]
          print(f"Raw data received: {sensor_data}")  # Debug line
          now = datetime.now().isoformat()
          
          #Saves raw sensor data row to CSV file
          with open(self.csv_file_path, 'a', newline='') as f:
              writer = csv.writer(f)
              writer.writerow([
                  now,
                  sensor_data[0],
                  sensor_data[1],
                  sensor_data[2],
                  sensor_data[3],
                  sensor_data[4],
                  sensor_data[5]
                  ])
          try:
            # Index 0: MCP9808 Temperature
            if self.recording_state["MCP9808 Temperature"]and sensor_data[0] != 0:
                self.data_record["MCP9808 Temperature"].append([now, sensor_data[0]])

            # Index 1: SHT45 Temperature
            if self.recording_state["SHT45 Temperature"] and sensor_data[1] != 0:
                self.data_record["SHT45 Temperature"].append([now, sensor_data[1]])

            # Index 2: SHT45 Humidity
            if self.recording_state["SHT45 Humidity"] and sensor_data[2] != 0:
                self.data_record["SHT45 Humidity"].append([now, sensor_data[2]])

            # Index 3: SCD4X CO2
            if self.recording_state["SCD4X CO2"] and sensor_data[3] != 0:
                self.data_record["SCD4X CO2"].append([now, sensor_data[3]])

            # Index 4: SCD4X Temperature
            if self.recording_state["SCD4X Temperature"] and sensor_data[4] != 0:
                self.data_record["SCD4X Temperature"].append([now, sensor_data[4]])

            # Index 5: SCD4X Humidity
            if self.recording_state["SCD4X Humidity"] and sensor_data[5] != 0:
                self.data_record["SCD4X Humidity"].append([now, sensor_data[5]])

          except Exception as e:
            print("Error processing serial data:", e)

    def openSensorPlot(self, idx):
        """Open (or focus) a live plot window for the specified sensor."""
        if idx in self.sensor_windows:
            self.sensor_windows[idx].raise_()
            self.sensor_windows[idx].activateWindow()
        else:
            window = SensorPlotWindow(idx, self)
            self.sensor_windows[idx] = window
            window.show()

    def openFile(self):
        """Open a JSON file containing sensor data."""
        file_name, _ = QFileDialog.getOpenFileName(
            self, "Open Data File", "", "JSON Files (*.json);;All Files (*)"
        )
        if file_name:
            try:
                with open(file_name, 'r', encoding='utf-8') as file:
                    data = json.load(file)
                self.data_record = data
                self.current_file = file_name
                self.updateData()
            except Exception as e:
                QMessageBox.warning(self, "Open File", f"Could not open file: {e}")


    #Function below saves sensor data to a current file or prompts user is file doesnt exist
    def saveFile(self):
        if self.current_file:
            try:
                with open(self.current_file, 'w', encoding='utf-8') as file:
                    json.dump(self.data_record, file, indent=4)
            except Exception as e:
                QMessageBox.warning(self, "Save File", f"Could not save file: {e}")
        else:
            self.saveFileAs()

    #Function below is about saving the sensor data to a named file
    def saveFileAs(self):
        file_name, _ = QFileDialog.getSaveFileName(
            self, "Save Data File", "", "JSON Files (*.json);;All Files (*)"
        )
        if file_name:
            self.current_file = file_name
            self.saveFile()
            
    #Function below saves the data as a CSV file with all the timestamps as a JSON file      
    def saveCSV(self):
        """Save sensor data to a CSV file."""
        file_name, _ = QFileDialog.getSaveFileName(
            self, "Save CSV File", "", "CSV Files (*.csv)"
    )

        if not file_name:
            return

        try:
            # Collect all timestamps
            timestamps = set()
            for sensor in self.sensor_names:
                for entry in self.data_record[sensor]:
                    timestamps.add(entry[0])

            timestamps = sorted(timestamps)

        # Create lookup dictionaries for each sensor
            sensor_lookup = {}
            for sensor in self.sensor_names:
                sensor_lookup[sensor] = {t: v for t, v in self.data_record[sensor]}

            with open(file_name, 'w', newline='') as f:
                writer = csv.writer(f)

            # Write header
            header = ["Timestamp"] + self.sensor_names
            writer.writerow(header)

            # Write rows
            for t in timestamps:
                row = [t]
                for sensor in self.sensor_names:
                    value = sensor_lookup[sensor].get(t, "")
                    row.append(value)
                writer.writerow(row)

            QMessageBox.information(self, "CSV Save", "Data successfully saved.")

        except Exception as e:
            QMessageBox.warning(self, "CSV Save Error", str(e))

    #Function below stops the serial worker and thread when GUI is closed
    def closeEvent(self, event):
        self.serial_worker.stop()
        self.serial_thread.quit()
        self.serial_thread.wait()
        event.accept()
        
