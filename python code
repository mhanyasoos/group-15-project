#The Serial reader worker runs in its own thread so that the GUI doesn't freeze
class SerialReaderWorker(QtCore.QObject):
    data_received = QtCore.pyqtSignal(list)
    
    def __init__(self, port, baudrate):
        super().__init__()
        self.port = port
        self.baudrate = baudrate
        self._running = True

#Function below opens serial port and  waits 5 seconds. arduino resets when serial opens

    def run(self):
        try:
            ser = serial.Serial(self.port, self.baudrate, timeout=1)
        except Exception as e:
                print("Could not open serial port:", e)
                return

        time.sleep(5)
        print(f"Listening on {self.port} ...")
    
        while self._running:
            try:
                line = ser.readline().decode('utf-8', errors='replace').strip()
                if not line:
                    continue
            
            # Parse CSV format (6 comma-separated values)
                parts = line.split(',')
                if len(parts) == 6:  # Expecting 6 values
                    try:
                        data = [float(x) for x in parts]
                        print("Received data:", data)
                        self.data_received.emit(data)
                    except ValueError as e:
                        print("Failed to parse CSV data:", line, e)
                        
                else:
                    print("Other message:", line)
            except Exception as e:
                print("Error reading serial:", e)


#This is opens a live graph for individual sensors

class SensorPlotWindow(QMainWindow):
    def __init__(self, sensor_index, main_window):
        super().__init__()
        self.sensor_index = sensor_index
        self.main_window = main_window  # Reference to main interface
        sensor_name = self.main_window.sensor_names[sensor_index]
        self.setWindowTitle(f"{sensor_name} - Live Plot")
        self.resize(600, 400)

        self.figure = Figure(figsize=(5, 3))
        self.canvas = FigureCanvas(self.figure)
        self.setCentralWidget(self.canvas)
        self.ax = self.figure.add_subplot(111)

        sensor_type = self.main_window.sensor_types[sensor_index]
        if sensor_type == "temperature":
            self.ax.set_ylabel("Temperature (C)")
        else:
            self.ax.set_ylabel("Humidity (%)")
        self.ax.set_xlabel("Time")
        # Create a line for the sensor data
        self.line, = self.ax.plot([], [], '-', label=sensor_name)
        self.ax.legend()

        # Timer to update the plot every second.
        self.timer = QtCore.QTimer(self)
        self.timer.setInterval(1000)
        self.timer.timeout.connect(self.updatePlot)
        self.timer.start()


    # Function below reads the stored data and extracts time, values and then redraws graph
    def updatePlot(self):
        data = self.main_window.data_record.get(self.main_window.sensor_names[self.sensor_index], [])
        if data:
            times = [datetime.fromisoformat(entry[0]) for entry in data]
            values = [entry[1] for entry in data]
            self.line.set_data(times, values)
            self.ax.set_xlim(times[0], times[-1])
            self.ax.relim()
            self.ax.autoscale_view(scalex=False, scaley=True)
        self.canvas.draw()

    def closeEvent(self, event):
        # Remove reference from the main window when closed.
        if self.sensor_index in self.main_window.sensor_windows:
            del self.main_window.sensor_windows[self.sensor_index]
        event.accept()
        
        

